{
    "name": "temant/settings-manager",
    "description": "A flexible, type-safe settings management library for PHP powered by Doctrine ORM.",
    "type": "library",
    "license": "MIT",
    "keywords": ["settings", "configuration", "doctrine", "orm", "php", "typed-settings"],
    "autoload": {
        "psr-4": {
            "Temant\\SettingsManager\\": "Src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Temant\\SettingsManager\\Tests\\": "Tests/"
        }
    },
    "require": {
        "php": "^8.5",
        "doctrine/orm": "^3"
    },
    "require-dev": {
        "phpstan/phpstan": "^2",
        "phpunit/phpunit": "^13",
        "symfony/cache": "^8.0"
    },
    "scripts": {
        "phpstan": "./vendor/bin/phpstan analyse",
        "phpunit": "./vendor/bin/phpunit",
        "check-all": [
            "@phpstan",
            "@phpunit"
        ]
    },
    "scripts-descriptions": {
        "phpstan": "Run PHPStan for static analysis",
        "phpunit": "Run PHPUnit tests",
        "check-all": "Run static analysis and tests"
    },
    "scripts-aliases": {
        "phpstan": ["stan", "analyze", "analyse"],
        "phpunit": ["test"]
    }
}
